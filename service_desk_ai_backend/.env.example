# Database Configuration
# Get your Postgres connection string from Supabase (Settings -> Database)
# Make sure to use the asyncpg dialect if required: postgresql+asyncpg://...
SUPABASE_DB_URL=postgresql+asyncpg://postgres:YourPasswordHere@db.yourproject.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET_KEY=generate_a_random_secure_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Provider Configuration (For OTP/Password Reset)
# e.g., SendGrid API Key
EMAIL_API_KEY=your_sendgrid_or_smtp_api_key_here

# Rate Limiting
# Optional rate limit constraints
RATE_LIMIT_PER_MINUTE=60
